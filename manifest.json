{
  "manifest_version": 3,
  "name": "VK Авто-отчёт",
  "description": "Автоматически отправляет отчёт в выбранный чат ВКонтакте по расписанию",
  "version": "1.1.0",
  "permissions": ["storage", "alarms", "tabs", "scripting"],
  "host_permissions": ["https://vk.com/*", "https://*.vk.com/*", "https://*.vk.me/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://vk.com/*", "https://*.vk.com/*", "https://*.vk.me/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "VK Авто-отчёт"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
